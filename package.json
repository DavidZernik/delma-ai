    "@mermaid-js/layout-elk": "^0.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.103.0",
    "ai": "^6.0.168",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "marked": "^18.0.0",
    "mermaid": "^11.14.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.20.0",
